# Supabase Postgres connection string (session pooler or direct)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# LLM provider keys (used by the routing tiebreaker and by tailoring; a provider with no key is skipped).
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=

# Tailoring (Phase 3): S3 bucket for base resumes + artifacts.
S3_BUCKET=
# AWS credentials are read from the standard AWS_* env vars / profile.

# The MCP server (python -m jobmaxxing.mcp) reads all of the above from the environment / .env.

# Google Sheets decision sheet (local sync_sheet worker; uv sync --extra sheets)
GSHEET_ID=
# Auth (pick ONE; precedence is top-to-bottom):
#  1. GOOGLE_OAUTH_CLIENT_FILE: path to your OWN OAuth client (Desktop-app) client_secret.json.
#     Recommended on personal accounts. First run opens a browser ("Google hasn't verified this app
#     -> Continue"), then caches a token next to the file (GOOGLE_OAUTH_TOKEN_FILE overrides the path).
GOOGLE_OAUTH_CLIENT_FILE=
GOOGLE_OAUTH_TOKEN_FILE=
#  2. GOOGLE_SERVICE_ACCOUNT_FILE: a service-account JSON key path (share the sheet with its email).
#     Often org-policy-blocked on new GCP projects.
GOOGLE_SERVICE_ACCOUNT_FILE=
#  3. Leave all of the above blank to use Application Default Credentials
#     (gcloud auth application-default login --scopes=<spreadsheets>,<drive>) — Google has been
#     deprecating the shared gcloud client for these scopes, so option 1 is the reliable path.

# Local web triage table (uv sync --extra web; python -m jobmaxxing.web). Optional; default 8765.
WEB_PORT=8765
