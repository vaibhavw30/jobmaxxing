# Supabase Postgres connection string (session pooler or direct)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# LLM provider keys (used by the routing tiebreaker and by tailoring; a provider with no key is skipped).
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=

# Tailoring (Phase 3): S3 bucket for base resumes + artifacts.
S3_BUCKET=
# AWS credentials are read from the standard AWS_* env vars / profile.

# The MCP server (python -m jobmaxxing.mcp) reads all of the above from the environment / .env.

# Google Sheets decision sheet (local sync_sheet worker; uv sync --extra sheets)
GSHEET_ID=
# Auth: leave GOOGLE_SERVICE_ACCOUNT_FILE BLANK to authenticate as yourself via Application Default
# Credentials (run once: gcloud auth application-default login --scopes=<spreadsheets>,<drive>).
# Only set it to a JSON key path if you use a service account instead (often blocked on new GCP projects).
GOOGLE_SERVICE_ACCOUNT_FILE=
