# Supabase Postgres connection string (session pooler or direct)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# LLM provider keys (used by the routing tiebreaker and by tailoring; a provider with no key is skipped).
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=

# Tailoring (Phase 3): S3 bucket for base resumes + artifacts.
S3_BUCKET=
# AWS credentials are read from the standard AWS_* env vars / profile.
